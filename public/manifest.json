      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Comandos",
      "url": "/#commands",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Configurações",
      "url": "/#config",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }]
    }
