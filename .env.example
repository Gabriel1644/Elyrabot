# ╔══════════════════════════════════════╗
# ║       ElyraBot — Configuração        ║
# ╚══════════════════════════════════════╝
# Execute "npm run config" para configurar interativamente!

# ── WhatsApp ──────────────────────────
OWNER_NUMBER=5511999999999
PREFIX=!
BOT_NAME=Elyra

# ── IA (Groq) ─────────────────────────
# Obtenha grátis em: https://console.groq.com
GROQ_API_KEY=sua_chave_aqui
GROQ_MODEL=llama-3.3-70b-versatile
BOT_PERSONALITY=Você é Elyra, uma assistente inteligente e elegante. Responda em português.

# ── Painel Web ────────────────────────
DASHBOARD_PORT=3000
# ⚠️ OBRIGATÓRIO para segurança — deixar vazio = painel sem autenticação (qualquer um acessa)
# Configure uma senha forte, especialmente se exposto via ngrok/internet
DASHBOARD_PASS=
DASHBOARD_AI=true

# ── APIs Opcionais ────────────────────
# openweathermap.org (para !clima)
WEATHER_KEY=

# ── Comportamento ─────────────────────
ANTI_SPAM=true
IA_DEFAULT=false
